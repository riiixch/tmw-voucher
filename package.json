{
  "name": "@riiixch/tmw-voucher",
  "version": "1.0.0",
  "description": "TrueMoney Wallet automatic voucher redeemer library with Cloudflare TLS fingerprint bypass",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
