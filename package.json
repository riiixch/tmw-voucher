    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "truemoney",
    "wallet",
    "voucher",
    "redeemer",
    "truemoney-voucher",
    "truemoney-gift",
    "cloudflare-bypass"
  ],
  "author": "RIIIXCH",
  "homepage": "https://github.com/riiixch/tmw-voucher#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/riiixch/tmw-voucher.git"
  },
